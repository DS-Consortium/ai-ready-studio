# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id

# QR Code Configuration
VITE_QR_ENVIRONMENT=production
VITE_QR_BASE_URL_PROD=https://aiready.dsconsortium.org
VITE_QR_BASE_URL_STAGING=https://staging.aiready.dsconsortium.org
VITE_QR_BASE_URL_DEV=http://localhost:5173

# Email Configuration
VITE_EMAIL_API_ENDPOINT=https://api.dsconsortium.org/email
VITE_EMAIL_FROM=noreply@dsconsortium.org

# Capacitor Configuration
VITE_CAPACITOR_PLATFORM=android

# Tutorial Video URL (optional)
# Set this to the URL of your hosted tutorial video
# Supported formats: MP4, WebM, HLS streams
# Examples:
#   - S3: https://your-bucket.s3.amazonaws.com/tutorial.mp4
#   - Vimeo: https://vimeo.com/123456789
#   - YouTube: https://www.youtube.com/embed/dQw4w9WgXcQ
#   - CDN: https://cdn.example.com/tutorial.webm
VITE_TUTORIAL_VIDEO_URL=

# Feature Flags
VITE_ENABLE_MODERATION=true
VITE_ENABLE_CALENDAR_EXPORT=true
