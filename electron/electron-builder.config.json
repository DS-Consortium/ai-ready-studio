{
  "appId": "com.dsconsortium.aiready",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "publish": {
    "provider": "github"
  },
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": [
      "nsis",
      "msix"
    ],
    "icon": "assets/appIcon.ico"
  },
  "msix": {
    "allowElevation": true,
    "oneClick": true,
    "identityName": "com.dsconsortium.aiready",
    "publisherDisplayName": "DS Consortium"
  },
  "mac": {
    "category": "your.app.category.type",
    "target": "dmg"
  }
}